# Google Maps API Key
# Get one at https://console.cloud.google.com/apis/credentials
#
# Required APIs to enable in your GCP project:
#   1. Maps SDK for Android  (for displaying the map)
#   2. Places API            (for searching boat launches, bait shops, gas stations)
#
# Copy your key here (without quotes):
GOOGLE_MAPS_API_KEY=AIzaSy...

# OpenWeatherMap API Key (optional — a default dev key is built-in)
# Get one at https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_key_here
