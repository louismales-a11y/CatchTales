rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pro licenses collection
    // - Cloud Function (admin SDK) can read/write all docs
    // - App users can only read a specific document if they know the code ID
    // - App users cannot list or write
    match /pro_licenses/{code} {
      allow read: if true;  // anyone can check if a code exists & is unused
      allow create, update, delete: if false;  // only cloud function (admin SDK) can write
    }

    // Usernames collection — anyone can check if a name exists (needed before sign-up)
    match /usernames/{name} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }

    // Existing app collections - require auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
